# Google AI Studio key for Gemini
GEMINI_API_KEY=

# Slack bot token (scopes: chat:write; bot must be a member of SLACK_CHANNEL_ID)
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL_ID=C

# Cloudflare R2 — the bucket (or this object key prefix) must be publicly readable
# so Slack can fetch and render the image_url.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket, e.g. https://pub-xxxxxxxx.r2.dev or a custom domain.
# The final image URL is "{R2_PUBLIC_URL_BASE}/menu-YYYY-MM-DD.png".
R2_PUBLIC_URL_BASE=

# Optional
RUST_LOG=info
